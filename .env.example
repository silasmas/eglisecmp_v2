APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Site public (SPA React dans resources/js/site) — clé API YouTube optionnelle (section enseignements)
# VITE_SITE_API_BASE=/api/site
# VITE_YOUTUBE_API_KEY=

# YouTube Data API (serveur Laravel) : récupère automatiquement youtube_duration_seconds après sauvegarde d'un post
# YOUTUBE_API_KEY=

# FlexPay (offrandes / mobile money + carte) — voir docs/integration-paiement-flexpay/
# FLEXPAY_API_TOKEN=
# FLEXPAY_MARCHAND=
# FLEXPAY_GATEWAY_MOBILE=https://backend.flexpay.cd/api/rest/v1/mobile
# FLEXPAY_GATEWAY_CARD=https://backend.flexpay.cd/api/rest/v1/card
# FLEXPAY_GATEWAY_CHECK=https://backend.flexpay.cd/api/rest/v1/check

# Filament Studio (https://github.com/flexpik/filament-studio)
STUDIO_API_ENABLED=false
# STUDIO_API_PREFIX=api/studio
# STUDIO_API_RATE_LIMIT=60
# STUDIO_PERMISSIONS_AUTO_REGISTER=true
# STUDIO_LOCALES_ENABLED=false

# Filament Connection Badge (https://filamentphp.com/plugins/rawand-rasool-connection-badge)
# Textes FR : lang/vendor/filament-connection-badge/fr/messages.php (actif si APP_LOCALE=fr)
# Paquets sans fichier fr/ : garder APP_FALLBACK_LOCALE=en pour retomber sur les chaînes anglaises du vendor.
# FILAMENT_CONNECTION_BADGE_ENABLED=true
# FILAMENT_CONNECTION_BADGE_RENDER_HOOK=panels::user-menu.before
# FILAMENT_CONNECTION_BADGE_THROTTLE=60,1
# Modal plein écran « hors ligne » : false par défaut dans config/filament-connection-badge.php
# FILAMENT_CONNECTION_BADGE_SHOW_OVERLAY=false
